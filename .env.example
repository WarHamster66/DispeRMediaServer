# Telegram
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=123456789
CREATOR_IDS=123456789,987654321

# Transmission RPC
TRANSMISSION_HOST=192.168.1.100
TRANSMISSION_PORT=9091
TRANSMISSION_USER=your_user
TRANSMISSION_PASSWORD=your_password

# Weather: no API key needed (Open-Meteo). Set the city in config.json (WEATHER_CITY).

# Optional: SOCKS5 proxy (leave empty if not needed)
PROXY_URL=socks5h://user:password@host:port
